# Reviews & orders are saved via Vercel Blob:
# Vercel Dashboard → Storage → Blob → connect to vaha-ruchulu → redeploy

# Owner password for dashboard (reviews + orders) — server only, do NOT prefix with VITE_
REVIEWS_ADMIN_PASSWORD=choose-a-strong-password

# Instant phone alerts via Telegram (recommended — free, 5 min setup)
# 1) Message @BotFather on Telegram → /newbot → copy token
# 2) Message your new bot once, then open:
#    https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates → find "chat":{"id": NUMBER}
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_OWNER_CHAT_ID=your-chat-id

# Email notifications (Gmail) — server only
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=vaharuchulu.pickles@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
OWNER_EMAIL=vaharuchulu.pickles@gmail.com

# Optional: Supabase instead of Blob for reviews (free at https://supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Your live website URL (for sharing)
VITE_SITE_URL=https://vaha-ruchulu.vercel.app
